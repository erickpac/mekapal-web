---
const steps = [
  {
    number: '1',
    title: 'Post Your Shipment',
    description:
      'Enter pickup, destination, cargo details, and preferred dates. Our system matches you with the best transporters.',
  },
  {
    number: '2',
    title: 'Choose a Transporter',
    description:
      'Review quotes, ratings, and vehicle info. Select the transporter that fits your needs and budget.',
  },
  {
    number: '3',
    title: 'Track & Settle',
    description:
      'Monitor your shipment in real time. Once delivered, payment is processed securely through the platform.',
  },
]
---

<section id="how-it-works" class="bg-white py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-4">
    <div class="text-center">
      <h2 class="fade-up text-3xl font-bold tracking-tight md:text-4xl">
        How It Works
      </h2>
      <p class="fade-up fade-up-delay-1 text-muted mx-auto mt-4 max-w-lg">
        Get your cargo moving in three simple steps.
      </p>
    </div>

    <div class="mt-16 grid gap-8 md:grid-cols-3">
      {
        steps.map(({ number, title, description }, i) => (
          <div class={`fade-up fade-up-delay-${i + 1} text-center`}>
            <div class="bg-primary/10 text-primary mx-auto flex size-14 items-center justify-center rounded-2xl text-xl font-bold">
              {number}
            </div>
            <h3 class="mt-5 text-lg font-semibold">{title}</h3>
            <p class="text-muted mt-2 text-sm leading-relaxed">{description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
