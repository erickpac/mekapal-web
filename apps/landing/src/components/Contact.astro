---

---

<section id="contact" class="bg-white py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-4">
    <div class="grid gap-12 lg:grid-cols-2">
      <div class="fade-up">
        <h2 class="text-3xl font-bold tracking-tight md:text-4xl">
          Ready to get started?
        </h2>
        <p class="text-muted mt-4">
          Fill out the form and our team will reach out within 24 hours to help
          you set up your account.
        </p>

        <div class="mt-8 space-y-4 text-sm">
          <div class="flex items-center gap-3">
            <svg
              class="text-primary size-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
            <span>info@mekapal.com</span>
          </div>
          <div class="flex items-center gap-3">
            <svg
              class="text-primary size-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path>
            </svg>
            <span>+502 2222-0000</span>
          </div>
          <div class="flex items-center gap-3">
            <svg
              class="text-primary size-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <span>Guatemala City, Guatemala</span>
          </div>
        </div>
      </div>

      <form
        id="contact-form"
        class="fade-up fade-up-delay-1 bg-surface grid gap-4 rounded-2xl border border-gray-200 p-6"
      >
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="c-name" class="mb-1 block text-sm font-medium"
              >Name</label
            >
            <input
              id="c-name"
              name="name"
              type="text"
              required
              class="focus:border-primary focus:ring-primary w-full rounded-lg border border-gray-200 bg-white px-3 py-2.5 text-sm transition-colors outline-none focus:ring-1"
            />
          </div>
          <div>
            <label for="c-email" class="mb-1 block text-sm font-medium"
              >Email</label
            >
            <input
              id="c-email"
              name="email"
              type="email"
              required
              class="focus:border-primary focus:ring-primary w-full rounded-lg border border-gray-200 bg-white px-3 py-2.5 text-sm transition-colors outline-none focus:ring-1"
            />
          </div>
        </div>

        <div>
          <label for="c-company" class="mb-1 block text-sm font-medium"
            >Company</label
          >
          <input
            id="c-company"
            name="company"
            type="text"
            class="focus:border-primary focus:ring-primary w-full rounded-lg border border-gray-200 bg-white px-3 py-2.5 text-sm transition-colors outline-none focus:ring-1"
          />
        </div>

        <div>
          <label for="c-message" class="mb-1 block text-sm font-medium"
            >Message</label
          >
          <textarea
            id="c-message"
            name="message"
            rows="4"
            required
            class="focus:border-primary focus:ring-primary w-full resize-none rounded-lg border border-gray-200 bg-white px-3 py-2.5 text-sm transition-colors outline-none focus:ring-1"
          ></textarea>
        </div>

        <button
          type="submit"
          class="bg-primary text-primary-foreground rounded-xl px-6 py-3 text-sm font-semibold transition-opacity hover:opacity-90"
        >
          Send Message
        </button>

        <p
          id="form-success"
          class="hidden text-center text-sm font-medium text-green-600"
        >
          Thanks! We'll be in touch soon.
        </p>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement
  const msg = document.getElementById('form-success')!

  form.addEventListener('submit', (e) => {
    e.preventDefault()
    // In production, submit to an API endpoint here
    form.reset()
    msg.classList.remove('hidden')
    setTimeout(() => msg.classList.add('hidden'), 4000)
  })
</script>
