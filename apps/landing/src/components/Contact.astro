---

<section
  id="contacto"
  class="bg-primary-700 relative isolate overflow-hidden py-16 text-white md:py-24 lg:py-28"
  aria-label="Contacto"
>
  <Image
    src={footerTexture}
    alt=""
    aria-hidden="true"
    class="absolute inset-0 -z-10 h-full w-full object-cover opacity-25 mix-blend-overlay"
    loading="lazy"
  />
  <div class="container-main">
    <div class="grid gap-10 lg:grid-cols-2 lg:gap-16">
      <!-- Left: contact info -->
      <div class="fade-up">
        <h2
          class="text-3xl font-extrabold tracking-tight md:text-4xl lg:text-5xl"
        >
          Contacto
        </h2>
        <p class="mt-4 max-w-md text-base leading-relaxed text-white/90">
          También puedes comunicarte con nosotros a través de los siguientes
          canales:
        </p>

        <ul class="mt-8 space-y-5 text-base">
          {
            channels.map(({ label, value }) => (
              <li>
                <p class="font-semibold">{label}</p>
                <p class="text-white/95">{value}</p>
              </li>
            ))
          }
        </ul>

        <div class="mt-8 flex flex-wrap gap-3">
          {
            socials.map(({ label, href, path }) => (
              <a
                href={href}
                aria-label={label}
                class="hover:bg-primary-50 flex size-10 items-center justify-center rounded-full bg-white text-primary-700 transition-colors"
              >
                <svg class="size-5 fill-current" viewBox="0 0 24 24">
                  <path d={path} />
                </svg>
              </a>
            ))
          }
        </div>
      </div>

      <!-- Right: contact form -->
      <form
        id="contact-form"
        class="fade-up fade-up-delay-1 grid gap-4 rounded-3xl bg-white p-6 shadow-xl md:p-8"
        novalidate
      >
        <div>
          <h3 class="text-text-active text-xl font-bold md:text-2xl">
            Comunicate con nosotros
          </h3>
          <p class="text-text-idle mt-1 text-sm">
            Déjanos tus datos y nos estaremos comunicando en brevedad contigo.
          </p>
        </div>

        <input
          id="c-name"
          name="name"
          type="text"
          required
          placeholder="Nombre*"
          aria-label="Nombre"
          class="border-light-gray-300 placeholder:text-text-idle focus:border-primary-500 focus:ring-primary-500/20 text-text-active w-full rounded-xl border bg-white px-4 py-3 text-sm transition-colors outline-none focus:ring-4"
        />

        <input
          id="c-phone"
          name="phone"
          type="tel"
          placeholder="Teléfono*"
          aria-label="Teléfono"
          class="border-light-gray-300 placeholder:text-text-idle focus:border-primary-500 focus:ring-primary-500/20 text-text-active w-full rounded-xl border bg-white px-4 py-3 text-sm transition-colors outline-none focus:ring-4"
        />

        <input
          id="c-email"
          name="email"
          type="email"
          required
          placeholder="Correo Electrónico*"
          aria-label="Correo electrónico"
          class="border-light-gray-300 placeholder:text-text-idle focus:border-primary-500 focus:ring-primary-500/20 text-text-active w-full rounded-xl border bg-white px-4 py-3 text-sm transition-colors outline-none focus:ring-4"
        />

        <textarea
          id="c-message"
          name="message"
          rows="4"
          required
          placeholder="Escribe tu mensaje aquí*"
          aria-label="Mensaje"
          class="border-light-gray-300 placeholder:text-text-idle focus:border-primary-500 focus:ring-primary-500/20 text-text-active w-full resize-none rounded-xl border bg-white px-4 py-3 text-sm transition-colors outline-none focus:ring-4"
        ></textarea>

        <button
          type="submit"
          class="bg-secondary-400 hover:bg-secondary-500 inline-flex items-center justify-center rounded-xl px-6 py-3.5 text-base font-semibold text-white shadow-sm transition-colors"
        >
          Enviar
        </button>

        <p
          id="contact-success"
          class="hidden text-center text-sm font-medium text-green-600"
        >
          ¡Gracias! Pronto te contactaremos.
        </p>
      </form>
    </div>
  </div>
</section>

<script>
  // TODO: wire contact form to backend or Formspree
  const form = document.getElementById('contact-form') as HTMLFormElement
  const success = document.getElementById('contact-success')!

  form.addEventListener('submit', (e) => {
    e.preventDefault()
    form.reset()
    success.classList.remove('hidden')
    setTimeout(() => success.classList.add('hidden'), 4000)
  })
</script>
