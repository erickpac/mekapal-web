---
const plans = [
  {
    name: 'Starter',
    price: 'Free',
    period: '',
    description: 'For small businesses getting started.',
    features: [
      'Up to 10 shipments/month',
      'Basic tracking',
      'Email support',
      'Standard settlements',
    ],
    cta: 'Get Started',
    highlighted: false,
  },
  {
    name: 'Professional',
    price: 'Q299',
    period: '/month',
    description: 'For growing businesses with regular shipments.',
    features: [
      'Unlimited shipments',
      'Real-time GPS tracking',
      'Priority support',
      'Fast settlements (48h)',
      'Analytics dashboard',
      'Custom reports',
    ],
    cta: 'Start Free Trial',
    highlighted: true,
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    period: '',
    description: 'For large operations with custom needs.',
    features: [
      'Everything in Professional',
      'Dedicated account manager',
      'API access',
      'Custom integrations',
      'SLA guarantee',
      'Multi-user accounts',
    ],
    cta: 'Contact Sales',
    highlighted: false,
  },
]
---

<section id="pricing" class="bg-white py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-4">
    <div class="text-center">
      <h2 class="fade-up text-3xl font-bold tracking-tight md:text-4xl">
        Simple, Transparent Pricing
      </h2>
      <p class="fade-up fade-up-delay-1 text-muted mx-auto mt-4 max-w-lg">
        Start free and scale as your business grows. No hidden fees.
      </p>
    </div>

    <div class="mt-16 grid gap-8 md:grid-cols-3">
      {
        plans.map(
          (
            { name, price, period, description, features, cta, highlighted },
            i,
          ) => (
            <div
              class={`fade-up fade-up-delay-${i + 1} flex flex-col rounded-2xl border p-7 ${
                highlighted
                  ? 'border-primary bg-primary/5 shadow-primary/10 shadow-lg'
                  : 'border-gray-200'
              }`}
            >
              {highlighted && (
                <span class="bg-primary text-primary-foreground mb-4 w-fit rounded-full px-3 py-1 text-xs font-semibold">
                  Most Popular
                </span>
              )}
              <h3 class="text-lg font-semibold">{name}</h3>
              <div class="mt-3 flex items-baseline gap-1">
                <span class="text-3xl font-bold">{price}</span>
                {period && <span class="text-muted text-sm">{period}</span>}
              </div>
              <p class="text-muted mt-2 text-sm">{description}</p>

              <ul class="mt-6 flex-1 space-y-3">
                {features.map((f) => (
                  <li class="flex items-start gap-2 text-sm">
                    <svg
                      class="text-primary mt-0.5 size-4 shrink-0"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M5 13l4 4L19 7"
                      />
                    </svg>
                    {f}
                  </li>
                ))}
              </ul>

              <a
                href="#contact"
                class={`mt-8 block rounded-xl py-3 text-center text-sm font-semibold transition-colors ${
                  highlighted
                    ? 'bg-primary text-primary-foreground hover:opacity-90'
                    : 'border border-gray-200 bg-white text-gray-700 hover:bg-gray-50'
                }`}
              >
                {cta}
              </a>
            </div>
          ),
        )
      }
    </div>
  </div>
</section>
