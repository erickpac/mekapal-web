---
import { Image } from 'astro:assets'
import expressIcon from '../assets/icons/express-service.svg'
import lightIcon from '../assets/icons/light-service.svg'
import heavyIcon from '../assets/icons/heavy-service.svg'

const services = [
  {
    icon: expressIcon,
    title: 'Envíos Express',
    subtitle: 'Rápidos y eficientes en Ciudad de Guatemala',
    description:
      'Servicio ideal para paquetes pequeños y entregas urgentes en zonas aledañas de la ciudad. Perfecto para documentos, productos ligeros y envíos que no pueden esperar.',
    bullets: [
      'Entregas el mismo día o en tiempos reducidos',
      'Atención ágil y personalizada',
      'Cobertura en áreas estratégicas de la ciudad',
    ],
  },
  {
    icon: lightIcon,
    title: 'Carga Liviana',
    subtitle: 'Ciudad de Guatemala y a toda la república',
    description:
      'Pensado para mercancía de mayor volumen que requiere un traslado cuidadoso y eficiente dentro de la ciudad o hacia otras zonas del país.',
    bullets: [
      'Manejo responsable de la carga',
      'Tiempos de entrega confiables',
      'Ideal para negocios y particulares',
    ],
  },
  {
    icon: heavyIcon,
    title: 'Carga Pesada',
    subtitle: 'Ciudad de Guatemala y a toda la república',
    description:
      'Servicio especializado para el traslado de muebles, electrodomésticos y objetos grandes o pesados, tanto en Ciudad de Guatemala como en el interior de la República.',
    bullets: [
      'Personal capacitado para cargas pesadas',
      'Transporte seguro y adecuado',
      'Ideal para mudanzas y traslados especiales',
    ],
  },
]
---

<section
  id="servicios"
  class="bg-primary-50 py-16 md:py-24 lg:py-28"
  aria-label="Nuestros servicios"
>
  <div class="container-main">
    <div>
      <h2
        class="fade-up text-text-active text-3xl font-extrabold tracking-tight md:text-4xl lg:text-5xl"
      >
        Nuestros servicios
      </h2>
      <p
        class="fade-up fade-up-delay-1 text-text-idle mt-4 max-w-2xl text-base md:text-lg"
      >
        Conoce los diferentes tipos de envíos que ofrecemos a través de nuestros
        transportistas afiliados.
      </p>
    </div>

    <div class="mt-12 grid gap-6 md:mt-16 md:grid-cols-2 lg:grid-cols-3 lg:gap-8">
      {
        services.map(({ icon, title, subtitle, description, bullets }, i) => (
          <article
            class={`fade-up fade-up-delay-${(i % 3) + 1} flex flex-col rounded-3xl bg-white p-6 shadow-sm md:p-8`}
          >
            <Image
              src={icon}
              alt=""
              aria-hidden="true"
              class="mx-auto h-24 w-auto md:h-28"
              loading="lazy"
            />
            <h3 class="text-text-active mt-4 text-center text-xl font-bold md:text-2xl">
              {title}
            </h3>
            <p class="text-text-active mt-2 text-center text-sm font-medium">
              {subtitle}
            </p>
            <p class="text-text-idle mt-4 text-sm leading-relaxed">
              {description}
            </p>
            <ul class="text-text-idle mt-5 list-disc space-y-2 pl-5 text-sm leading-relaxed marker:text-text-active">
              {bullets.map((b) => (
                <li>{b}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>

    <div class="fade-up mt-12 flex justify-center md:mt-16">
      <a
        href="#inicio"
        class="bg-secondary-500 hover:bg-secondary-600 inline-flex items-center justify-center rounded-full px-8 py-3.5 text-base font-semibold text-white shadow-md transition-colors"
      >
        Descarga la App
      </a>
    </div>
  </div>
</section>
