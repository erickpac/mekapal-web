<section
  class="to-surface relative overflow-hidden bg-gradient-to-br from-white pt-28 pb-20 md:pt-36 md:pb-28"
>
  <div class="mx-auto max-w-6xl px-4 text-center">
    <h1
      class="fade-up mx-auto max-w-3xl text-4xl leading-tight font-bold tracking-tight md:text-6xl"
    >
      Logistics made
      <span class="text-primary">simple</span>
      for Guatemala
    </h1>

    <p
      class="fade-up fade-up-delay-1 text-muted mx-auto mt-6 max-w-xl text-lg md:text-xl"
    >
      Connect with verified transporters, manage shipments in real time, and
      settle payments — all from one platform.
    </p>

    <div
      class="fade-up fade-up-delay-2 mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center"
    >
      <a
        href="#contact"
        class="bg-primary text-primary-foreground shadow-primary/25 rounded-xl px-8 py-3.5 text-base font-semibold shadow-lg transition-all hover:opacity-90"
      >
        Start Free
      </a>
      <a
        href="#how-it-works"
        class="rounded-xl border border-gray-200 bg-white px-8 py-3.5 text-base font-semibold text-gray-700 transition-colors hover:border-gray-300 hover:bg-gray-50"
      >
        See How It Works
      </a>
    </div>
  </div>

  <!-- Decorative gradient blob -->
  <div
    class="bg-primary/10 pointer-events-none absolute -top-40 -right-40 size-96 rounded-full blur-3xl"
    aria-hidden="true"
  >
  </div>
</section>
