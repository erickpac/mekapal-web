---
import { Image } from 'astro:assets'
import heroLandscape from '../assets/hero/hero-landscape.png'
import appHero from '../assets/mockups/app-hero.png'
---

<section
  id="inicio"
  class="relative isolate overflow-hidden text-white"
  aria-label="Inicio"
>
  <!-- Background image -->
  <Image
    src={heroLandscape}
    alt=""
    aria-hidden="true"
    class="absolute inset-0 -z-10 h-full w-full object-cover"
    loading="eager"
    fetchpriority="high"
  />
  <div
    class="absolute inset-0 -z-10 bg-gradient-to-b from-black/25 via-black/15 to-black/35"
    aria-hidden="true"
  >
  </div>

  <div
    class="container-main flex flex-col gap-10 pt-28 pb-16 md:pt-32 md:pb-24 lg:flex-row lg:items-center lg:gap-12 lg:pt-36 lg:pb-32"
  >
    <!-- Left: copy -->
    <div class="w-full text-left lg:w-1/2">
      <h1
        class="fade-up text-4xl leading-[1.05] font-extrabold tracking-tight text-balance md:text-6xl lg:text-7xl"
      >
        Movemos tus chivas por ti
      </h1>

      <p
        class="fade-up fade-up-delay-1 mt-6 max-w-xl text-base leading-relaxed text-white/95 md:text-lg"
      >
        Mekapal es la plataforma logística que conecta clientes con
        transportistas independientes en Guatemala. Solicita tu envío, recibe
        ofertas competitivas y mueve tu carga a donde la necesites.
      </p>

      <!-- Store badges -->
      <div
        class="fade-up fade-up-delay-2 mt-8 flex flex-wrap items-center justify-start gap-3 sm:gap-4"
      >
        <a
          href="#"
          aria-label="Descargar en Google Play"
          class="transition-transform hover:scale-[1.03]"
        >
          <img
            src="/badges/google-play.svg"
            alt="Google Play"
            class="h-12 w-auto md:h-14"
            loading="eager"
          />
        </a>
        <a
          href="#"
          aria-label="Descargar en App Store"
          class="transition-transform hover:scale-[1.03]"
        >
          <img
            src="/badges/app-store.svg"
            alt="App Store"
            class="h-12 w-auto md:h-14"
            loading="eager"
          />
        </a>
        <a
          href="#"
          aria-label="Descargar en AppGallery"
          class="transition-transform hover:scale-[1.03]"
        >
          <img
            src="/badges/app-gallery.svg"
            alt="AppGallery"
            class="h-12 w-auto md:h-14"
            loading="eager"
          />
        </a>
      </div>
    </div>

    <!-- Right: phone mockup -->
    <div class="fade-up fade-up-delay-2 flex w-full justify-center lg:w-1/2">
      <Image
        src={appHero}
        alt="Aplicación Mekapal en un iPhone"
        class="h-auto w-72 max-w-full sm:w-80 md:w-96 lg:w-full lg:max-w-md xl:max-w-lg"
        loading="eager"
      />
    </div>
  </div>
</section>
