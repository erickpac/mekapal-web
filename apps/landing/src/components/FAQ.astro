---
const faqs = [
  {
    q: 'How does Mekapal verify transporters?',
    a: 'Every transporter goes through a verification process that includes document review, vehicle inspection, and background checks before they can accept shipments.',
  },
  {
    q: 'What types of cargo can I ship?',
    a: 'Mekapal supports both light and heavy cargo. From small packages to full truckloads, our network covers a wide range of transportation needs.',
  },
  {
    q: 'How long does it take to receive payment?',
    a: 'Transporters on the Professional plan receive payment within 48 hours of confirmed delivery. Starter plan settlements are processed within 5 business days.',
  },
  {
    q: 'Is there a minimum contract period?',
    a: 'No. All plans are month-to-month with no long-term commitment. You can upgrade, downgrade, or cancel at any time.',
  },
  {
    q: 'What areas does Mekapal cover?',
    a: 'We currently operate throughout Guatemala, covering all major routes and municipalities. We are actively expanding to neighboring countries.',
  },
  {
    q: 'Can I integrate Mekapal with my existing systems?',
    a: 'Enterprise plan customers get full API access for custom integrations with ERP systems, warehouse management software, and more.',
  },
]
---

<section id="faq" class="bg-surface py-20 md:py-28">
  <div class="mx-auto max-w-3xl px-4">
    <div class="text-center">
      <h2 class="fade-up text-3xl font-bold tracking-tight md:text-4xl">
        Frequently Asked Questions
      </h2>
      <p class="fade-up fade-up-delay-1 text-muted mx-auto mt-4 max-w-lg">
        Everything you need to know about using Mekapal.
      </p>
    </div>

    <div class="mt-12 divide-y divide-gray-200">
      {
        faqs.map(({ q, a }, i) => (
          <details class={`fade-up fade-up-delay-${(i % 3) + 1} group py-5`}>
            <summary class="flex cursor-pointer items-center justify-between text-left font-medium">
              {q}
              <svg
                class="text-muted size-5 shrink-0 transition-transform group-open:rotate-45"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 4v16m8-8H4"
                />
              </svg>
            </summary>
            <p class="text-muted mt-3 text-sm leading-relaxed">{a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
