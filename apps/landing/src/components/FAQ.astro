---
// TODO: real FAQ answers pending
const placeholder =
  'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.'

const faqs = [
  { q: '¿Puedo ser cliente y transportista a la vez?', a: placeholder },
  {
    q: '¿Cuál es la diferencia entre carga liviana y carga pesada?',
    a: placeholder,
  },
  { q: '¿Cómo me registro como transportista?', a: placeholder },
  {
    q: '¿Debo tener asegurado mi vehículo para operar como transportista?',
    a: placeholder,
  },
  { q: '¿Cómo funcionan las comisiones?', a: placeholder },
  { q: '¿Cómo funciona Mekapal?', a: placeholder },
  {
    q: '¿Qué impuestos me corresponden pagar a mí si soy transportista?',
    a: placeholder,
  },
  { q: '¿Qué áreas cubre el servicio de Envío Express?', a: placeholder },
]
---

<section
  id="faq"
  class="bg-secondary-50 py-16 md:py-24 lg:py-28"
  aria-label="Preguntas frecuentes"
>
  <div class="container-main">
    <div>
      <h2
        class="fade-up text-text-active text-3xl font-extrabold tracking-tight md:text-4xl lg:text-5xl"
      >
        Preguntas Frecuentes
      </h2>
      <p
        class="fade-up fade-up-delay-1 text-text-idle mt-4 max-w-2xl text-base md:text-lg"
      >
        Encuentra aquí las respuestas que estás buscando.<br />
        Si no la encuentras, puedes
        <a href="#contacto" class="text-primary-500 font-medium hover:underline">
          contactarnos aquí.
        </a>
      </p>
    </div>

    <div class="mt-10 flex flex-col gap-3 md:mt-14">
      {
        faqs.map(({ q, a }, i) => (
          <details
            class={`fade-up fade-up-delay-${(i % 3) + 1} group bg-white rounded-2xl border border-transparent open:border-secondary-500 transition-colors`}
          >
            <summary class="text-text-active flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 text-left text-base font-semibold md:px-6 md:py-5 md:text-lg">
              <span>{q}</span>
              <svg
                class="text-text-active size-5 shrink-0 transition-transform group-open:rotate-180"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 9l-7 7-7-7"
                />
              </svg>
            </summary>
            <div class="text-text-idle px-5 pb-5 text-sm leading-relaxed md:px-6 md:pb-6 md:text-base">
              {a}
            </div>
          </details>
        ))
      }
    </div>

    <div class="fade-up mt-10 flex justify-center md:mt-12">
      <a
        href="#contacto"
        class="bg-secondary-500 hover:bg-secondary-600 inline-flex items-center justify-center rounded-full px-8 py-3.5 text-base font-semibold text-white shadow-md transition-colors"
      >
        Ver Más
      </a>
    </div>
  </div>
</section>
